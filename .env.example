# ============================================
# D-CloudX Environment Configuration
# ============================================
# Copy this file to .env and configure with your values
# DO NOT commit .env to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION
# ============================================
MONGODB_URI=mongodb://localhost:27017/dcloudx
REDIS_URL=redis://localhost:6379
DATABASE_HOST=mongodb
DATABASE_PORT=27017
DATABASE_NAME=dcloudx
DATABASE_USER=root
DATABASE_PASSWORD=changeme

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# JWT & SECURITY
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=7d
BCRYPT_ROUNDS=10

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================
# Network RPC URLs
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your-infura-key
MAINNET_RPC_URL=https://mainnet.infura.io/v3/your-infura-key
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
POLYGON_RPC_URL=https://polygon-rpc.com
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# Deployment & Keys
ETHEREUM_RPC_URL=http://localhost:8545
PRIVATE_KEY=0x...your-private-key-here
BLOCKCHAIN_CONTRACT_ADDRESSES=./contracts/deployments.json

# Etherscan API Key (for contract verification)
ETHERSCAN_API_KEY=your-etherscan-api-key
ARBISCAN_API_KEY=your-arbiscan-api-key
POLYGONSCAN_API_KEY=your-polygonscan-api-key

# ============================================
# CLOUD PROVIDER CREDENTIALS
# ============================================
# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-west-2

# Azure
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id

# Google Cloud Platform
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_KEY=./docker/gcp-key.json

# ============================================
# FRONTEND CONFIGURATION
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_BLOCKCHAIN_RPC_URL=http://localhost:8545
NEXT_PUBLIC_CHAIN_ID=1
NEXT_PUBLIC_CONTRACT_ADDRESSES=./contracts/deployments.json
NEXT_PUBLIC_INFURA_KEY=your-infura-key
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ============================================
# MONITORING & OBSERVABILITY
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_PORT=9200
LOGSTASH_ENABLED=true

# Sentry for error tracking
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=development

# ============================================
# DOCKER REGISTRY
# ============================================
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your-github-username
DOCKER_PASSWORD=your-github-token

# ============================================
# GITHUB ACTIONS / CI/CD
# ============================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# MAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
MAIL_FROM=noreply@dcloudx.io

# ============================================
# OPTIONAL: Advanced Configuration
# ============================================
# Cache Configuration
CACHE_TTL=300
CACHE_MAX_SIZE=1000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET=your-session-secret-key
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true

# API Configuration
API_VERSION=v1
API_TIMEOUT=30000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,https://dcloudx.io
