{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "lib": ["ES2021"],
    "outDir": "./artifacts",
    "rootDir": "./contracts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": false,
    "moduleResolution": "node"
  },
  "include": ["contracts/**/*", "scripts/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}
